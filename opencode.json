{
    "$schema": "https://opencode.ai/config.json",
    "permissions": {
        "*": "ask",
        "bash": "ask",
        "edit": {
            "*":            "deny",
            "llm/*.typ":    "allow"
        },
        "read": {
            "*":                "deny",
            "llm/*.typ":        "allow",
            "paper/*.pdf":      "allow",
            "book/*.pdf":       "allow",
            "template/*.typ":   "allow"
        },
        "write": {
            "*":            "deny",
            "llm/*.typ":    "allow"
        }
    }
}
